        "id": "qp004_q3",
        "text": "Which tense is used for an action that started in the past and continues now?",
        "options": [
          { "id": "a", "text": "Simple Past" },
          { "id": "b", "text": "Past Perfect" },
          { "id": "c", "text": "Present Perfect Continuous" },
          { "id": "d", "text": "Future Perfect" }
